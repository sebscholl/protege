{
  "providers": [
    "openai",
    "anthropic",
    "gemini",
    "grok",
    "openrouter"
  ],
  "tools": [
    "shell",
    "glob",
    "search",
    "read-file",
    "write-file",
    "edit-file",
    "web-fetch",
    "web-search",
    "send-email",
    "search-email"
  ],
  "hooks": [
    {
      "name": "thread-memory-updater",
      "events": [
        "harness.inference.completed"
      ]
    },
    {
      "name": "active-memory-updater",
      "events": [
        "memory.thread.updated"
      ]
    }
  ],
  "resolvers": [
    "load-file",
    "thread-memory-state",
    "invocation-metadata",
    "thread-history",
    "current-input"
  ]
}

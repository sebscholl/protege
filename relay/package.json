{
  "name": "protege-relay",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "relay:start": "tsx src/main.ts",
    "relay:test:ws-auth": "tsx scripts/manual-ws-auth-test.ts",
    "relay:listen:ws-inbox": "tsx scripts/manual-ws-inbox.ts",
    "relay:deploy:sync": "bash deploy/scripts/sync-to-server.sh",
    "relay:deploy:remote": "bash deploy/scripts/deploy-remote.sh",
    "relay:deploy": "bash deploy/scripts/deploy-via-ssh.sh",
    "relay:server:bootstrap": "bash deploy/scripts/server-bootstrap.sh",
    "relay:server:restart": "bash deploy/scripts/server-restart.sh",
    "relay:server:status": "bash deploy/scripts/server-status.sh",
    "relay:server:logs": "bash deploy/scripts/server-logs.sh",
    "relay:server:health": "bash deploy/scripts/server-health.sh",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "mailauth": "^4.13.1",
    "nodemailer": "^8.0.1",
    "smtp-server": "^3.18.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@types/nodemailer": "^7.0.9",
    "@types/smtp-server": "^3.5.12",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "eslint": "^9.20.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  }
}
